# Folder ini berisi logika & kredensial API — hanya index.php yang boleh
# dieksekusi langsung (dipanggil lewat rewrite /api/* di .htaccess root).
# db.php dan config.local.php* TIDAK boleh diakses langsung dari browser.

<FilesMatch "\.php$">
    Require all denied
</FilesMatch>
<Files "index.php">
    Require all granted
</Files>
