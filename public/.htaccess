# =====================================================================
#  Kepengurusan — konfigurasi Apache (dipakai saat deploy, bukan php -S)
#  DocumentRoot vhost HARUS diarahkan ke folder public/ ini.
# =====================================================================

# Jangan tampilkan daftar isi folder
Options -Indexes

# Halaman default
DirectoryIndex index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # /api/*  ->  front controller (REQUEST_URI tetap /api/... agar routing benar)
    RewriteRule ^api(/.*)?$ api.php [L,QSA]

    # SPA fallback: jika path bukan file/direktori nyata -> index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

# Tolak akses ke file tersembunyi (mis. .htaccess, .env)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Cache aset statis (opsional, mempercepat)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|svg|png|jpg|jpeg|gif|woff2?)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>
